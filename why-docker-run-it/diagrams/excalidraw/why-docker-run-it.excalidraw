      "seed": 2099319053,
      "version": 196,
      "versionNonce": 410611747,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1768990330792,
      "link": null,
      "locked": false,
      "text": "When a normal cat program is run, its stdin, stdout, and stderr streams will be connected with controlling terminal (user's terminal) of the session. \nwhatever user types in the console goes to the program's standard input and everything the program prints comes back to the console",
      "fontSize": 28,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "When a normal cat program is run, its stdin, stdout, and stderr streams will be connected with controlling terminal (user's terminal) of the session. \nwhatever user types in the console goes to the program's standard input and everything the program prints comes back to the console",
      "autoResize": true,
      "lineHeight": 1.25
    },
