      "isDeleted": false,
      "boundElements": null,
      "updated": 1769001424784,
      "link": null,
      "locked": false,
      "text": "docker run itself is a compounded command that has internal sequence of other basic\ndocker commands to run like\n\nimage pull - container create - container attach- network connect - container start\n",
      "fontSize": 28,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "docker run itself is a compounded command that has internal sequence of other basic docker commands to run like\n\nimage pull - container create - container attach- network connect - container start\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
