      "updated": 1769005580379,
      "link": null,
      "locked": false,
      "text": "Using -t without -i creates a pseudo-terminal without input.",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Using -t without -i creates a pseudo-terminal without input.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "AGSQWgBr-Qmr7bE9jTU99",
      "type": "text",
      "x": 511.29421488444007,
      "y": 5210.730316371302,
      "width": 977.1786499023438,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3w",
      "roundness": null,
      "seed": 195396813,
      "version": 140,
      "versionNonce": 1291891949,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1769005580379,
      "link": null,
      "locked": false,
      "text": "Shells like bash enter a non-interactive, non-job-control state where Ctrl-C and exit do not behave normally.",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Shells like bash enter a non-interactive, non-job-control state where Ctrl-C and exit do not behave normally.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "K5EuGoCnUafbEEM5zyJyQ",
      "type": "text",
      "x": 511.29421488444007,
      "y": 5240.730316371302,
      "width": 436.7393798828125,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3x",
      "roundness": null,
      "seed": 251378307,
      "version": 141,
      "versionNonce": 1716883277,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1769005580379,
      "link": null,
      "locked": false,
      "text": "A usable interactive shell requires both -i and -t.",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A usable interactive shell requires both -i and -t.",
      "autoResize": true,
      "lineHeight": 1.25
    },
