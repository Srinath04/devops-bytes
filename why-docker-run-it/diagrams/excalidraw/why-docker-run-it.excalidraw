      "isDeleted": true,
      "boundElements": null,
      "updated": 1769005574272,
      "link": null,
      "locked": false,
      "text": "-i flag tells the docker run command to keep the container's STDIN open. This is\nessential when piping data from the Docker host into a containerized command.",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "-i flag tells the docker run command to keep the container's STDIN open. This is essential when piping data from the Docker host into a containerized command.",
      "autoResize": false,
      "lineHeight": 1.25
    },
